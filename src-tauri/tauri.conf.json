{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "scs-rclient",
  "version": "0.1.0",
  "identifier": "online.anthonyis.scs-rclient",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "scs-rclient",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Anthony",
    "shortDescription": "SCS Rclone Client",
    "copyright": "see license",
    "category": "Utility",
    "targets": [
      "nsis",
      "msi",
      "deb",
      "appimage",
      "dmg"
    ],
    "externalBin": [
      "binaries/rclone-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
